# Copy to scripts/update.env and fill in for your NAS.
# This file is sourced by scripts/update.sh. Real values stay gitignored.

NAS_TYPE=ugreen              # ugreen | synology | qnap | unraid | truenas
DEPLOY_HOST=192.168.1.50     # NAS IP or hostname
# DEPLOY_USER=admin          # defaults to your local $USER
# DEPLOY_PATH=/volume1/docker/brise   # auto-discovered if unset
# SKIP_TEST=false
# ASSUME_YES=true
