---
import Sidebar from "../components/atoms/Sidebar.astro";
import Toast from "../components/components/Toast.astro";
import WelcomeModal from "../components/components/WelcomeModal.astro";
import "../styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Apply saved theme before page renders to prevent flash
      const saved = localStorage.getItem("theme");
      if (saved === "light") {
        document.documentElement.classList.add("js-light");
      }
    </script>
    <style>
      /* ═══════════════════════════════════════════════════════════════
         PAGE SKELETON — shown during initial paint, faded out by JS
         ═══════════════════════════════════════════════════════════════ */
      .page-skeleton {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: var(--bg-primary);
        transition: opacity 0.35s ease;
      }
      .js-skeleton-fadeout {
        opacity: 0;
        pointer-events: none;
      }
      .page-skeleton-inner {
        display: flex;
        height: 100%;
      }
      .skeleton-sidebar {
        width: 220px;
        flex-shrink: 0;
        background: var(--bg-secondary);
        border-right: 1px solid var(--border-primary);
      }
      .skeleton-main {
        flex: 1;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .skeleton-header {
        height: 2.5rem;
        width: 12rem;
        border-radius: 0.5rem;
        background: var(--bg-secondary);
        animation: skeleton-pulse 1.6s ease-in-out infinite;
      }
      .skeleton-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }
      .skeleton-card {
        height: 6.5rem;
        border-radius: 0.75rem;
        background: var(--bg-secondary);
        animation: skeleton-pulse 1.6s ease-in-out infinite;
      }
      .skeleton-charts {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
      }
      .skeleton-chart {
        height: 12rem;
        border-radius: 0.75rem;
        background: var(--bg-secondary);
        animation: skeleton-pulse 1.6s ease-in-out infinite;
      }
      @keyframes skeleton-pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.45;
        }
      }
      @media (max-width: 768px) {
        .skeleton-sidebar {
          display: none;
        }
        .skeleton-main {
          padding: 1rem;
          padding-top: 4rem;
        }
      }
    </style>
  </head>
  <body>
    <!-- Skeleton screen: hidden once JS initializes -->
    <div id="page-skeleton" class="page-skeleton">
      <div class="page-skeleton-inner">
        <div class="skeleton-sidebar"></div>
        <div class="skeleton-main">
          <div class="skeleton-header"></div>
          <div class="skeleton-grid">
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
            <div class="skeleton-card"></div>
          </div>
          <div class="skeleton-charts">
            <div class="skeleton-chart"></div>
            <div class="skeleton-chart"></div>
          </div>
        </div>
      </div>
    </div>

    <Sidebar />

    <main class="main-content">
      <slot />
    </main>

    <Toast />
    <WelcomeModal />

    <div class="wave">
      <svg
        viewBox="0 0 1440 120"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z"
          fill="var(--bg-waves)"></path>
      </svg>
    </div>
    <script>
      import { initI18n, setLocale, applyTranslations } from '../i18n/index.js';

      // Init locale + fill all data-i18n elements
      initI18n();

      // Locale select handler — instant switch, no reload
      const localeSelect = document.getElementById('locale-select');
      if (localeSelect) {
        localeSelect.addEventListener('change', () => {
          setLocale(localeSelect.value);
          applyTranslations();
        });
      }

      // Hide skeleton after translations are applied
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          const sk = document.getElementById("page-skeleton");
          if (sk) {
            sk.classList.add("js-skeleton-fadeout");
            setTimeout(() => { sk.style.display = "none"; }, 350);
          }
        });
      });
    </script>
  </body>
</html>
