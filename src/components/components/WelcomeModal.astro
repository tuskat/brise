<div id="welcome-modal" class="modal welcome-modal js-hidden">
  <div class="welcome-modal-card">
    <div style="font-size:3rem;margin-bottom:1rem">⚠️</div>
    <h1 class="t-hero c-warning" data-i18n="welcome.title"></h1>
    <p class="t-title c-secondary t-weight-500" style="margin:0 0 1.5rem" data-i18n="welcome.subtitle"></p>
    
    <div class="welcome-modal-warning">
      <p class="c-warning t-weight-600 t-caption m-0 mb-sm" data-i18n="warning.exposingMayResult"></p>
      <ul class="welcome-modal-list c-primary t-caption">
        <li data-i18n="warning.unauthorizedAccess"></li>
        <li data-i18n="warning.apiKeyTheft"></li>
        <li data-i18n="warning.promptInjection"></li>
        <li data-i18n="warning.resourceAbuse"></li>
      </ul>
    </div>
    
    <p class="c-secondary t-caption mb-md" data-i18n="warning.deployTrusted"></p>
    
    <button id="welcome-acknowledge-btn" class="btn btn-primary btn-lg" data-i18n="welcome.acknowledge"></button>
  </div>
</div>

<script is:inline>
  (function() {
    const STORAGE_KEY = 'brise_welcomed';
    
    function checkWelcome() {
      const modal = document.getElementById('welcome-modal');
      if (!modal) return;
      if (localStorage.getItem(STORAGE_KEY) === 'true') {
        modal.classList.add('js-hidden');
      } else {
        modal.classList.remove('js-hidden');
      }
    }
    
    document.addEventListener('DOMContentLoaded', function() {
      checkWelcome();
      var btn = document.getElementById('welcome-acknowledge-btn');
      if (btn) {
        btn.addEventListener('click', function() {
          localStorage.setItem(STORAGE_KEY, 'true');
          var modal = document.getElementById('welcome-modal');
          if (modal) modal.classList.add('js-hidden');
        });
      }
      window.showWelcomeModal = function() {
        var modal = document.getElementById('welcome-modal');
        if (modal) modal.classList.remove('js-hidden');
      };
    });
  })();
</script>
