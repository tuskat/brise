<div id="proxies-view" class="m-10 js-hidden min-h-100vw">
  <div class="row-between flex-wrap gap-lg">
    <div>
      <h2 class="t-hero" data-i18n="proxies.title"></h2>
      <p class="t-subtitle" data-i18n="proxies.subtitle"></p>
    </div>
    <button
      id="new-proxy-btn"
      class="btn btn-primary"
      data-i18n="proxies.addProxy"></button>
  </div>

  <div id="proxies-list" class="flex-col gap-md mt-lg">
    <p class="placeholder" data-i18n="proxies.loading"></p>
  </div>
</div>

 <!-- Proxy Form Modal -->
  <div id="proxy-form-modal" class="modal">
    <div class="modal-card">
      <div class="row-between mb-md">
        <h2
          id="proxy-form-title"
          class="t-section-title"
          data-i18n="proxies.form.newTitle"
        >
        </h2>
        <button
          id="proxy-form-close"
          class="modal-close"
          data-i18n-aria="general.close">&times;</button
        >
      </div>
      <form id="proxy-form" class="flex-col gap-md">
        <div class="flex-col gap-xs">
          <label for="px-name" class="label" data-i18n="proxies.form.name"
          ></label>
          <input
            id="px-name"
            type="text"
            class="input"
            data-i18n-placeholder="proxies.form.namePlaceholder"
            required
          />
        </div>
        <div class="flex-col gap-xs">
          <label for="px-url" class="label" data-i18n="proxies.form.url"
          ></label>
          <input
            id="px-url"
            type="text"
            class="input"
            data-i18n-placeholder="proxies.form.urlPlaceholder"
            required
          />
          <span
            id="px-url-hint"
            class="t-caption c-tertiary"
            data-i18n="proxies.form.urlHintOllama"></span>
        </div>
        <div class="flex-col gap-xs">
          <label
            for="px-schema"
            class="label"
            data-i18n="proxies.form.apiSchema"></label>
          <select id="px-schema" class="input input-select">
            <option value="ollama" data-i18n="proxies.form.schemaOllama"
            ></option>
            <option value="openai" data-i18n="proxies.form.schemaOpenai"
            ></option>
          </select>
          <span class="t-caption c-tertiary" data-i18n="proxies.form.schemaHint"
          ></span>
        </div>
        <div class="flex-col gap-xs">
          <label for="px-model" class="label" data-i18n="proxies.form.model"
          ></label>
          <input
            id="px-model"
            type="text"
            class="input"
            data-i18n-placeholder="proxies.form.modelPlaceholder"
            required
          />
          <span class="t-caption c-tertiary" data-i18n="proxies.form.modelHint"
          ></span>
        </div>
        <div class="flex-col gap-sm">
          <label class="flex-row gap-sm t-body c-primary cursor-pointer">
            <input id="px-local" type="checkbox" checked />
            <span data-i18n="proxies.form.isLocal"></span>
          </label>
          <span class="t-caption c-tertiary" data-i18n="proxies.form.localHint"
          ></span>
        </div>
        <div id="api-key-field" class="flex-col gap-xs js-hidden">
          <label for="px-apikey" class="label" data-i18n="proxies.form.apiKey"
          ></label>
          <input
            id="px-apikey"
            type="password"
            class="input"
            data-i18n-placeholder="proxies.form.apiKeyPlaceholder"
          />
          <span
            class="t-caption c-warning"
            data-i18n="proxies.form.apiKeyWarning"></span>
        </div>
        <div class="flex-row gap-sm flex-wrap">
          <button
            type="submit"
            class="btn btn-primary"
            id="proxy-form-submit"
            data-i18n="proxies.form.createBtn"></button>
          <button
            type="button"
            class="btn btn-secondary"
            id="proxy-form-cancel"
            data-i18n="general.cancel"></button>
        </div>
      </form>
    </div>
  </div>

  <div id="proxy-delete-modal" class="modal">
    <div class="modal-card modal-card-sm">
      <h2 class="t-section-title" data-i18n="proxies.delete.title"></h2>
      <p
        id="proxy-delete-confirm-text"
        class="t-body c-secondary"
        style="margin:0.75rem 0 0"
      >
      </p>
      <div class="flex-row gap-sm self-end mt-sm flex-wrap">
        <button
          id="confirm-proxy-delete-btn"
          class="btn btn-danger-fill"
          data-i18n="general.delete"></button>
        <button
          id="cancel-proxy-delete-btn"
          class="btn btn-secondary"
          data-i18n="general.cancel"></button>
      </div>
    </div>
  </div>