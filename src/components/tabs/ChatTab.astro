<div id="chat-view" class="chat-conversation js-hidden">
  <div class="chat-layout">
    <!-- Main Area -->
    <main id="chat-main" class="chat-main">
      <!-- Empty State -->
      <div id="chat-empty-state" class="chat-empty flex-col row-center">
        <div class="empty-state-icon c-tertiary opacity-50 mb-md">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h2 class="t-title" data-i18n="chat.startNew"></h2>
        <p class="t-caption c-secondary mt-sm" style="max-width:20rem" data-i18n="chat.configureHint"></p>
        <button id="chat-open-sidebar-btn" class="btn btn-primary" style="margin-top:1.25rem" data-i18n="chat.startChatting"></button>
      </div>

      <!-- Thread View -->
      <div id="chat-thread" class="chat-thread flex-col js-hidden">
        <header class="chat-thread-header">
          <div class="flex-row gap-md">
            <h2 id="conversation-title" class="t-title" data-i18n="chat.newConversation"></h2>
            <button id="edit-title-btn" class="btn btn-secondary" style="padding:0.375rem;" data-i18n-title="chat.editTitle">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
            </button>
          </div>
          <span id="conversation-model" class="badge badge-neutral"></span>
          <span id="conversation-persona" class="badge badge-persona" style="display:none"></span>
        </header>

        <div id="message-list" class="flex-col gap-lg chat-messages"></div>

        <footer class="flex-row gap-md" style="padding:1rem 1.5rem 1.75rem;border-top:1px solid var(--border-primary);background:var(--bg-secondary);align-items:flex-end">
          <textarea
            id="chat-input"
            class="input input-textarea chat-input-textarea"
            data-i18n-placeholder="chat.typeMessage"
            rows="1"
          ></textarea>
          <button id="send-message-btn" class="btn btn-primary chat-send-btn" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </footer>
      </div>
    </main>

    <!-- Right Sidebar -->
    <aside id="chat-sidebar" class="chat-sidebar flex-col">
      <!-- Collapsible Config Section -->
      <div id="chat-config-section" class="chat-config-section">
        <button id="chat-config-toggle" class="chat-config-toggle" data-i18n-title="chat.toggleConfig">
          <svg class="chat-config-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
          <span class="t-caption t-weight-500" data-i18n="chat.config"></span>
        </button>
        <div id="chat-config-content" class="chat-config-content flex-col gap-md" style="padding:1rem">
          <div class="flex-col gap-sm">
            <div class="flex-col gap-xs">
              <label class="label" for="chat-persona-select" data-i18n="chat.persona"></label>
              <select id="chat-persona-select" class="input">
                <option value="" data-i18n="general.default"></option>
              </select>
            </div>
            <div class="flex-col gap-xs">
              <label class="label" for="chat-proxy-select" data-i18n="chat.proxy"></label>
              <select id="chat-proxy-select" class="input">
                <option value="" data-i18n="general.loading"></option>
              </select>
            </div>
          </div>
          <button id="new-chat-btn" class="btn btn-primary w-100 row-center gap-xs">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            <span data-i18n="chat.newChat"></span>
          </button>
        </div>
      </div>

      <!-- Search + Conversation List -->
      <div class="chat-sidebar-list-area">
        <div class="chat-sidebar-search">
          <input
            type="text"
            id="chat-search"
            class="input"
            data-i18n-placeholder="chat.searchConversations"
          />
        </div>
        <div id="conversation-list" class="chat-sidebar-list"></div>
      </div>
    </aside>
    <div id="chat-sidebar-backdrop" class="chat-sidebar-backdrop"></div>
  </div>

  <!-- Sidebar Toggle (visible on desktop + mobile, right-side, chat icon) -->
  <button id="chat-sidebar-toggle" class="chat-sidebar-toggle-btn js-active">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
  </button>
</div>

<!-- Title Edit Modal -->
<div id="title-edit-modal" class="modal">
  <div class="modal-card modal-card-sm">
    <div class="row-between mb-md">
      <h3 class="t-section-title" data-i18n="chat.renameConversation"></h3>
    </div>
    <div class="flex-col gap-md">
      <div class="flex-col gap-xs">
        <label class="label" for="title-input" data-i18n="chat.title"></label>
        <input type="text" id="title-input" class="input" data-i18n-placeholder="chat.enterNewTitle" />
      </div>
      <div class="flex-row gap-sm self-end mt-sm flex-wrap">
        <button id="cancel-title-btn" class="btn btn-secondary" data-i18n="general.cancel"></button>
        <button id="save-title-btn" class="btn btn-primary" data-i18n="general.save"></button>
      </div>
    </div>
  </div>
</div>

<script>
  import { initChatView } from '../../utils/chat-init.js';
  window.initChatView = initChatView;
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initChatView);
  } else {
    initChatView();
  }
</script>
